<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:paddingHorizontal="24dp"
    android:paddingTop="48dp"
    android:paddingBottom="16dp"
    tools:context=".concerto.ConcertoFragment">

    <!-- Header — mirrors profile fragment header:
         leave/back on the left, "CONCERTO" centered, End Session right -->
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Leave button (host: acts as back, guest: leave) -->
        <ImageButton
            android:id="@+id/btnLeaveSession"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_button_minimize"
            android:rotation="90"
            android:scaleType="fitCenter"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="CONCERTO"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- End Session — host only, right side -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnTempLeave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Step Out"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:includeFontPadding="false"
            android:background="@drawable/bg_button_outline"
            android:minHeight="0dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:stateListAnimator="@null"
            android:visibility="gone" />

    </RelativeLayout>

    <!-- Join Code — "Username" label style (24sp bold) -->
    <TextView
        android:id="@+id/tvSessionPin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Join Code: ----"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="@font/plus_jakarta_sans_regular"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnHostSkip" />

    <!-- Skip button — host only, sits inline with Join Code -->
    <ImageButton
        android:id="@+id/btnHostSkip"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_media_next"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:visibility="gone"
        app:tint="#AAAAAA"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvSessionPin"
        app:layout_constraintBottom_toBottomOf="@+id/tvSessionPin" />

    <!-- Now Playing card — same shape, primary color accents -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardNowListening"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@+id/tvSessionPin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivNowPlayingArt"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:src="@drawable/img_album_placeholder"
                android:background="@drawable/bg_rounded_corner_smallest"
                android:clipToOutline="true" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvNowPlayingLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOW PLAYING"
                    android:textColor="@color/primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvNowPlayingTrack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Track Name"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvNowPlayingArtist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Artist"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

            <!-- Pulse dots — guests only, primary color -->
            <LinearLayout
                android:id="@+id/layoutListeningDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:visibility="gone">
                <View android:id="@+id/dot1" android:layout_width="4dp" android:layout_height="4dp"
                    android:background="@color/primary" android:layout_marginEnd="3dp" />
                <View android:id="@+id/dot2" android:layout_width="4dp" android:layout_height="4dp"
                    android:background="@color/primary" android:layout_marginEnd="3dp" />
                <View android:id="@+id/dot3" android:layout_width="4dp" android:layout_height="4dp"
                    android:background="@color/primary" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- "Up Next" label — muted, small, same as dashboard section labels -->
    <TextView
        android:id="@+id/tvQueueLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Up Next"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/cardNowListening"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Queue RecyclerView — same style as rvDashboardTracks:
         paddingBottom 76dp, clipToPadding false, vertical scrollbars -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvConcertoQueue"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:paddingBottom="76dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@+id/tvQueueLabel"
        app:layout_constraintBottom_toTopOf="@+id/btnAddSong" />

    <!-- Add Song — mirrors btnGoToSignup style (small, outline, centered) -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAddSong"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Add a Song"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:includeFontPadding="false"
        android:background="@drawable/bg_button_outline"
        android:minHeight="0dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
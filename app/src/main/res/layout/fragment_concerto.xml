<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".concerto.ConcertoFragment">

    <TextView
        android:id="@+id/tvSessionPin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Join Code: ----"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnTempLeave" />

    <!-- Host only: step out without ending the session -->
    <Button
        android:id="@+id/btnTempLeave"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step Out"
        android:textColor="#AAAAAA"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@+id/btnLeaveSession"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@+id/tvSessionPin" />

    <Button
        android:id="@+id/btnLeaveSession"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Leave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@+id/tvSessionPin" />

    <!-- Unified Now Playing card — shown for ALL users when a track is active -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardNowListening"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@+id/tvSessionPin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivNowPlayingArt"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:src="@drawable/img_album_placeholder"
                android:background="@drawable/bg_rounded_corner_smallest"
                android:clipToOutline="true" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvNowPlayingLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOW PLAYING"
                    android:textColor="#1DB954"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tvNowPlayingTrack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Track Name"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvNowPlayingArtist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Artist"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Pulse dots — guests only -->
            <LinearLayout
                android:id="@+id/layoutListeningDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:visibility="gone">
                <View android:id="@+id/dot1" android:layout_width="4dp" android:layout_height="4dp"
                    android:background="#1DB954" android:layout_marginEnd="3dp" />
                <View android:id="@+id/dot2" android:layout_width="4dp" android:layout_height="4dp"
                    android:background="#1DB954" android:layout_marginEnd="3dp" />
                <View android:id="@+id/dot3" android:layout_width="4dp" android:layout_height="4dp"
                    android:background="#1DB954" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvQueueLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Up Next"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#AAAAAA"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@+id/cardNowListening"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btnHostSkip"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_media_next"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvQueueLabel"
        app:layout_constraintBottom_toBottomOf="@+id/tvQueueLabel" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvConcertoQueue"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@+id/tvQueueLabel"
        app:layout_constraintBottom_toTopOf="@+id/btnAddSong" />

    <Button
        android:id="@+id/btnAddSong"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Search and Add Song"
        app:icon="@android:drawable/ic_menu_search"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
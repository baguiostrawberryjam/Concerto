<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp"
    android:background="@color/background">

    <!-- Title — matches tvGenre in fragment_dashboard -->
    <TextView
        android:id="@+id/tvSearchTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Search"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        android:fontFamily="@font/plus_jakarta_sans_regular" />

    <!-- Search bar: white rounded box with icon + EditText inside -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_search_input"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/btnSearch"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search_line"
            android:scaleType="fitCenter"
            android:layout_marginEnd="8dp"
            app:tint="#888888" />

        <EditText
            android:id="@+id/etSearchQuery"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Songs, artists, albums..."
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:maxLines="1"
            android:textColor="#000000"
            android:textColorHint="#888888"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:paddingStart="0dp"
            android:paddingEnd="8dp" />

    </LinearLayout>

    <!-- Results label — smaller than tvGenre, same style family -->
    <TextView
        android:id="@+id/tvResultsLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Results"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone"
        android:fontFamily="@font/plus_jakarta_sans_regular" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="48dp"
        android:indeterminateTint="@color/primary"
        android:visibility="gone" />

    <!-- Empty state — centered, muted, with search illustration feel -->
    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter a track name to start searching."
        android:textAlignment="center"
        android:textColor="#555555"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginTop="64dp"
        android:layout_marginHorizontal="32dp" />

    <!-- Results list — same padding pattern as rvDashboardTracks -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchTracks"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        android:visibility="gone" />

</LinearLayout>
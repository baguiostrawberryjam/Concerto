<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".concerto.ConcertoLobbyFragment">

    <TextView
        android:id="@+id/tvLobbyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Concerto"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvLobbySubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Listen together in real-time."
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/tvLobbyTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnCreateConcerto"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Create a Concerto"
        android:textSize="16sp"
        app:icon="@android:drawable/ic_menu_add"
        app:iconGravity="textStart"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toBottomOf="@+id/tvLobbySubtitle" />

    <TextView
        android:id="@+id/tvCreateHelper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Requires Spotify Premium to act as the host speaker."
        android:textSize="12sp"
        android:textAlignment="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/btnCreateConcerto" />

    <View
        android:id="@+id/dividerLeft"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginEnd="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tvOr"
        app:layout_constraintTop_toTopOf="@+id/tvOr"
        app:layout_constraintBottom_toBottomOf="@+id/tvOr" />

    <TextView
        android:id="@+id/tvOr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OR"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@+id/tvCreateHelper"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/dividerRight"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toEndOf="@+id/tvOr"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvOr"
        app:layout_constraintBottom_toBottomOf="@+id/tvOr" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPinInput"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@+id/tvOr">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etConcertoPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter 4-Digit Join PIN"
            android:inputType="number"
            android:maxLength="4"
            android:textAlignment="center"
            android:textSize="18sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnJoinConcerto"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Join Concerto"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/tilPinInput" />

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="32dp">

    <!-- Header — same pattern as signup fragment -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="44dp">

        <ImageButton
            android:id="@+id/btnBackFromLobby"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_button_minimize"
            android:rotation="90"
            android:scaleType="fitCenter"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="LOBBY"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- "Join PIN" label — mirrors "Username" label from signup -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Join PIN"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="@font/plus_jakarta_sans_regular"
        android:layout_marginBottom="6dp" />

    <!-- PIN input — mirrors the Username input box from signup -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <EditText
            android:id="@+id/etConcertoPin"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="Enter 4-digit PIN"
            android:inputType="number"
            android:maxLength="4"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:paddingStart="0dp" />
    </LinearLayout>

    <!-- Subtext below input — mirrors tvUsernameStatus style -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Collaborate to create the ultimate playlist"
        android:textColor="#555555"
        android:textSize="11sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp" />

    <!-- Join button — mirrors btnLogin exactly (wrap_content, 50dp, centered) -->
    <Button
        android:id="@+id/btnJoinConcerto"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_gravity="center_horizontal"
        android:text="Join"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:includeFontPadding="false"
        android:layout_marginBottom="24dp" />

    <!-- Create button — mirrors btnGoToSignup exactly (AppCompatButton, bg_button_outline, small) -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCreateConcerto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Create a Concerto instead"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:includeFontPadding="false"
        android:background="@drawable/bg_button_outline"
        android:minHeight="0dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:stateListAnimator="@null" />

</LinearLayout>